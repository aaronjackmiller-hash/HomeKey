PORT=5000
# Replace <username> and <password> with your Atlas credentials.
# The database name (homekey) must appear between the host and the "?" —
# Atlas copies the SRV string without it, which causes Mongoose to connect
# to the default "test" database instead.
# If your password contains special characters (@ # ! % etc.) URL-encode them
# e.g. p@ss -> p%40ss
# Atlas users are usually created in the "admin" auth database.
# If you get "Authentication failed" in Render logs, add authSource=admin.
# Atlas may also provide a "standard connection string" with multiple hosts
# and :27017 ports (mongodb://...host1:27017,host2:27017,...). That format is
# valid too; keep it exactly as provided and ensure /homekey is the database.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.XXXXX.mongodb.net/homekey?retryWrites=true&w=majority&authSource=admin&appName=Cluster0
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
ADMIN_SECRET=change_this_to_a_random_admin_secret

# Optional Twilio SMS confirmations.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# TWILIO_FROM_NUMBER is also accepted for deployments that already use this name.
TWILIO_FROM_NUMBER=

# Optional AI search interpretation. If no key is set, mobile AI search uses
# HomeKey's deterministic fallback parser.
OPENAI_API_KEY=
AI_SEARCH_MODEL=gpt-4o-mini

# Optional social auth + passkey config
GOOGLE_CLIENT_ID=
REACT_APP_GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
PASSKEY_RP_NAME=HomeKey
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:3000
