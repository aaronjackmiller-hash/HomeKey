PORT=5000
# Replace <username> and <password> with your Atlas credentials.
# The database name (homekey) must appear between the host and the "?" —
# Atlas copies the SRV string without it, which causes Mongoose to connect
# to the default "test" database instead.
# If your password contains special characters (@ # ! % etc.) URL-encode them
# e.g. p@ss -> p%40ss
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.XXXXX.mongodb.net/homekey?retryWrites=true&w=majority&appName=Cluster0
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
