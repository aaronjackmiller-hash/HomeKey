{
  "name": "homekey-backend",
  "version": "1.0.0",
  "description": "Backend API for HomeKey real estate platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "node scripts/renderPostinstall.js",
    "seed": "node seed.js",
    "yad2:backfill": "node services/yad2BackfillService.js",
    "render-build": "npm ci --prefix ../frontend && NODE_OPTIONS=\"--openssl-legacy-provider --max-old-space-size=384\" CI=false npm run build --prefix ../frontend && test -f ../frontend/build/index.html && npm install"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.19.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.12.0",
    "google-auth-library": "^10.6.2",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^6.13.6",
    "twilio": "^5.3.0"
  }
}
